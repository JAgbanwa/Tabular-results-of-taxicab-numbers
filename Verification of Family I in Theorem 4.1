// Define the quadratic field Q(sqrt(3))
K<sqrt3> := QuadraticField(3);

// Define integer parameters (replace with concrete values if desired)
x0 := K!2;   // Example: fundamental solution x0=2, y0=1
y0 := K!1;   // Example

// Set values for m and k (you can loop over these)
m := 101;
k := 15;

// Define powers of (x0 +/- y0*sqrt(3))^k
Xp := (x0 + y0*sqrt3)^k;
Xm := (x0 - y0*sqrt3)^k;

// Family I definitions
Bm := (-2*3^(m+2) + 3^m*((7 - 5*sqrt3)*Xm + (7 + 5*sqrt3)*Xp))/4;
Cm := (-2*3^(m+1) + 3^m*((15 - 7*sqrt3)*Xm + (15 + 7*sqrt3)*Xp))/4;
Am := Cm + 3^(m+1);
Dm := Bm + 3^(m+2);

// Verify the identity
LHS := Am^3 + Bm^3;
RHS := Cm^3 + Dm^3;

print "A_m^3 + B_m^3 = ", LHS;
print "C_m^3 + D_m^3 = ", RHS;
if LHS eq RHS then
    print "Identity verified!";
else
    print "Identity FAILED!";
end if;
